# Local working keys for this checkout only.
# They are never versioned and are not encrypted by sops.
keys/*
!keys/ssh/
!keys/age/

keys/ssh/*
!keys/ssh/.gitkeep

keys/age/*
!keys/age/.gitkeep

# Rendered, secret-bearing artifacts (cloud-init user-data, etc.).
# The TEMPLATES live under targets/hosts/<host>/cloud-init.yaml and ARE versioned;
# the rendered output containing the age private key never is.
keys/*.user-data
keys/*-cloud-init.yaml
